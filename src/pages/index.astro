    <!-- CASE STUDIES -->
    <section id="case-studies" class="section">
        <div class="container">
            <div class="section-header">
                <div class="overline">Verified Results</div>
                <h2>3 Companies. Millions Saved. <span class="gradient-text">Zero Fluff.</span></h2>
                <p>Every metric below is sourced directly from the company's internal finance and ops data.</p>
            </div>

            <div class="case-grid">

                <!-- ====== CASE STUDY 1: AUTOMATED WORKFLOWS ====== -->
                <article class="case-card">
                    <div class="case-card-header">
                        <span class="case-tag tag-workflows">Automated Workflows</span>
                        <h3>How FinServ Corp Automated 12,000 Manual Processes Per Month</h3>
                        <div class="case-company">Financial Services · 2,400 Employees</div>
                    </div>

                    <div class="case-metrics">
                        <div class="metric-box">
                            <div class="metric-value" style="color:#22d3ee;">12,847</div>
                            <div class="metric-label">Processes/Month</div>
                        </div>
                        <div class="metric-box">
                            <div class="metric-value" style="color:#22d3ee;">93.2%</div>
                            <div class="metric-label">Accuracy Rate</div>
                        </div>
                        <div class="metric-box">
                            <div class="metric-value" style="color:#22d3ee;">14 hrs</div>
                            <div class="metric-label">Saved / Employee / Wk</div>
                        </div>
                        <div class="metric-box">
                            <div class="metric-value" style="color:#22d3ee;">3 days</div>
                            <div class="metric-label">Implementation Time</div>
                        </div>
                    </div>

                    <div class="case-body">
                        <h4>The Challenge</h4>
                        <ul>
                            <li>24 full-time employees spent 70% of their week copying data between CRM, ERP, and spreadsheets</li>
                            <li>Average processing time per invoice: 47 minutes, with a 14% error rate requiring rework</li>
                            <li>Customer onboarding took 11 business days due to manual document verification and data entry</li>
                        </ul>

                        <h4>The AI Automation Solution</h4>
                        <ul>
                            <li>Deployed an AI-powered document processing pipeline using n8n + OpenAI GPT-4 to extract, validate, and route invoices automatically</li>
                            <li>Built intelligent RAG-based workflows that handle customer queries and update CRM records without human intervention</li>
                            <li>Trained an anomaly detection model to flag high-risk transactions, reducing compliance review backlog by 78%</li>
                        </ul>

                        <blockquote>
                            "We went from 11 days to 4 hours for customer onboarding. The AI handles the grunt work; our team focuses on relationships and complex exceptions."
                            <span class="attribution">— Sarah Chen, VP of Operations at FinServ Corp</span>
                        </blockquote>

                        <div class="tech-stack">
                            <span class="tech-tag">n8n</span>
                            <span class="tech-tag">OpenAI API</span>
                            <span class="tech-tag">LangChain</span>
                            <span class="tech-tag">PostgreSQL</span>
                            <span class="tech-tag">Slack Bot</span>
                        </div>

                        <a href="https://n8n.io/?affiliate_id=ai-automation-showcase" class="case-cta case-cta-workflows" rel="nofollow sponsored" target="_blank">
                            🔧 Try n8n Automation — Free Tier Available →
                        </a>
                    </div>
                </article>

                <!-- ====== CASE STUDY 2: COST SAVINGS ====== -->
                <article class="case-card">
                    <div class="case-card-header">
                        <span class="case-tag tag-cost">Cost Savings</span>
                        <h3>How RetailMax Cut Customer Support Costs by 67% — Without Losing CSAT</h3>
                        <div class="case-company">E-commerce Retail · $340M Annual Revenue</div>
                    </div>

                    <div class="case-metrics">
                        <div class="metric-box">
                            <div class="metric-value" style="color:#a78bfa;">$890K</div>
                            <div class="metric-label">Annual Savings</div>
                        </div>
                        <div class="metric-box">
                            <div class="metric-value" style="color:#a78bfa;">67%</div>
                            <div class="metric-label">Cost Reduction</div>
                        </div>
                        <div class="metric-box">
                            <div class="metric-value" style="color:#a78bfa;">4.6 → 4.8</div>
                            <div class="metric-label">CSAT Score Improved</div>
                        </div>
                        <div class="metric-box">
                            <div class="metric-value" style="color:#a78bfa;">82%</div>
                            <div class="metric-label">Auto-Resolved</div>
                        </div>
                    </div>

                    <div class="case-body">
                        <h4>The Challenge</h4>
                        <ul>
                            <li>Support team of 52 agents handled 85,000+ tickets/month at $10.40 average cost per ticket</li>
                            <li>31% of tickets were simple password resets, order status checks, and returns — high volume, low value</li>
                            <li>Peak season (Black Friday, holidays) required hiring 28 temporary workers at $3,200 per head</li>
                        </ul>

                        <h4>The AI Automation Solution</h4>
